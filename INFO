package="openclaw"
version="1.3.0"
os_min_ver="7.2-42661"

# Package Center metadata

displayname="OpenClaw"
description="Self-hosted AI agent platform (OpenClaw)"
arch="noarch"
maintainer="Backhand"
maintainer_url="https://github.com/backhand"
package_url="https://github.com/backhand/openclaw-synology"

# Control
startable="yes"
ctl_stop="yes"

# Package Center Open button (fallback)
adminprotocol="http"
adminport="18789"
adminurl="/"
port="18789"
adminloginpage="index.cgi"

# Open in a DSM window (desktop app integration)
dsmuidir="ui"
dsmappname="com.openclaw.OpenClaw"

# Require Synology Node.js package
install_dep_packages="Node.js_v22"