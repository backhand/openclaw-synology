#!/bin/sh
set -eu
PKG_DIR="$SYNOPKG_PKGDEST"
APP_DIR="$PKG_DIR/app"
mkdir -p "$APP_DIR"
# Fetch OpenClaw source (no git dependency)
TMP_TGZ="$SYNOPKG_PKGINST_TEMP/openclaw-src.tgz"
URL="https://github.com/openclaw/openclaw/archive/refs/heads/main.tar.gz"
/bin/curl -L "$URL" -o "$TMP_TGZ"
/bin/tar -xzf "$TMP_TGZ" -C "$APP_DIR" --strip-components=1
cd "$APP_DIR"
# Install dependencies
npm ci --omit=dev > "$SYNOPKG_TEMP_LOGFILE" 2>&1 || npm install --omit=dev >> "$SYNOPKG_TEMP_LOGFILE" 2>&1
# Ensure writable runtime dirs
mkdir -p "$PKG_DIR/var"
exit 0
