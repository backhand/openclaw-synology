#!/bin/sh
set -eu
LOGFILE="${SYNOPKG_TEMP_LOGFILE:-/tmp/openclaw-postinst.log}"
exec >>"$LOGFILE" 2>&1

PKG_NAME="${SYNOPKG_PKGNAME:-openclaw}"
PKG_DEST="${SYNOPKG_PKGDEST:-/var/packages/${PKG_NAME}/target}"
PKG_HOME="/var/packages/${PKG_NAME}/home"

APP_DIR="$PKG_DEST/app"
VAR_DIR="$PKG_DEST/var"
NPM_CACHE="$VAR_DIR/npm-cache"

echo "[openclaw] postinst: starting" 
date

echo "[openclaw] PKG_DEST=$PKG_DEST" 
echo "[openclaw] PKG_HOME=$PKG_HOME"
echo "[openclaw] node=$(node --version 2>/dev/null || echo MISSING)"
echo "[openclaw] npm=$(npm --version 2>/dev/null || echo MISSING)"

mkdir -p "$APP_DIR" "$VAR_DIR" "$NPM_CACHE" "$PKG_HOME"
# Persist installer log somewhere easy to tail later
ln -sf "$LOGFILE" "$VAR_DIR/install.log" || true

# Ensure npm uses writable dirs
export HOME="$PKG_HOME"
export npm_config_cache="$NPM_CACHE"

URL="https://github.com/openclaw/openclaw/archive/refs/heads/main.tar.gz"
TMPBASE="${SYNOPKG_PKGINST_TEMP:-/tmp}"
TMP_TGZ="$TMPBASE/openclaw-src.tgz"
TMP_DIR="$TMPBASE/openclaw-src"

echo "[openclaw] Downloading $URL -> $TMP_TGZ"
curl -fSL --retry 3 --retry-delay 2 "$URL" -o "$TMP_TGZ"

echo "[openclaw] Extracting (portable)"
rm -rf "$TMP_DIR"
mkdir -p "$TMP_DIR"
rm -rf "$APP_DIR"/*

tar -xzf "$TMP_TGZ" -C "$TMP_DIR"
TOP_DIR="$(find "$TMP_DIR" -mindepth 1 -maxdepth 1 -type d | head -n 1)"
if [ -z "$TOP_DIR" ] || [ ! -d "$TOP_DIR" ]; then
  echo "[openclaw] ERROR: could not locate extracted top dir" 
  ls -la "$TMP_DIR" || true
  exit 1
fi
cp -a "$TOP_DIR"/. "$APP_DIR"/

cd "$APP_DIR"

echo "[openclaw] Installing node deps (npm ci --omit=dev)"
if npm ci --omit=dev; then
  echo "[openclaw] npm ci ok"
else
  echo "[openclaw] npm ci failed, retrying npm install --omit=dev"
  npm install --omit=dev
fi

echo "[openclaw] postinst: done"
exit 0
