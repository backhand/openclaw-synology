#!/bin/sh
set -eu

PKG_NAME="${SYNOPKG_PKGNAME:-openclaw}"
PKG_DEST="${SYNOPKG_PKGDEST:-/var/packages/${PKG_NAME}/target}"
PKG_HOME="/var/packages/${PKG_NAME}/home"
APP_DIR="$PKG_DEST/app"
VAR_DIR="$PKG_DEST/var"
NPM_CACHE="$VAR_DIR/npm-cache"

UI_LOG="${SYNOPKG_TEMP_LOGFILE:-/tmp/openclaw-postinst-ui.log}"
VERBOSE_LOG="$VAR_DIR/install.log"
mkdir -p "$APP_DIR" "$VAR_DIR" "$NPM_CACHE" "$PKG_HOME"
exec 3>"$UI_LOG"
exec >>"$VERBOSE_LOG" 2>&1

echo "[openclaw] Installing… (details: $VERBOSE_LOG)" >&3

NODE_BIN=""
NPM_BIN=""
for p in /var/packages/Node.js_v22/target/usr/local/bin/node /var/packages/Node.js_v22/target/bin/node /usr/local/bin/node $(command -v node 2>/dev/null || true); do
  if [ -n "$p" ] && [ -x "$p" ]; then NODE_BIN="$p"; break; fi
done
for p in /var/packages/Node.js_v22/target/usr/local/bin/npm /var/packages/Node.js_v22/target/bin/npm /usr/local/bin/npm $(command -v npm 2>/dev/null || true); do
  if [ -n "$p" ] && [ -x "$p" ]; then NPM_BIN="$p"; break; fi
done

echo "[openclaw] node=$NODE_BIN npm=$NPM_BIN"
[ -n "$NODE_BIN" ] && [ -n "$NPM_BIN" ]

export HOME="$PKG_HOME"
export npm_config_cache="$NPM_CACHE"
cd "$APP_DIR"
if [ ! -f package.json ]; then
  "$NPM_BIN" init -y >/dev/null 2>&1 || true
fi

echo "[openclaw] npm install openclaw"
"$NPM_BIN" install --omit=dev openclaw

echo "[openclaw] Running npm audit fix"
"$NPM_BIN" audit fix || echo "[openclaw] Audit fix skipped (non-critical)"

echo "[openclaw] Setting UI permissions"
chmod -R 755 "$PKG_DEST/ui"

# Create DSM app symlink (for proper "Open" integration)
# Create DSM app symlink with sudo fallback
LN_CMD="ln -sf \"$PKG_DEST/ui\" /usr/syno/synoman/webman/3rdparty/OpenClaw"
if command -v sudo >/dev/null && sudo $LN_CMD; then
  echo "[openclaw] Created webman symlink (via sudo)" >&3
elif $LN_CMD; then
  echo "[openclaw] Created webman symlink" >&3
else
  echo "[openclaw] WARNING: Failed to create webman symlink (permissions?)" >&3
fi

# Create minimal OpenClaw config (in package home dir)
CONFIG_DIR="$PKG_HOME/.openclaw"
CONFIG_FILE="$CONFIG_DIR/openclaw.json"
mkdir -p "$CONFIG_DIR"
cat > "$CONFIG_FILE" <<EOF
{
  "gateway": {
    "mode": "local",
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  }
}
EOF
chmod 600 "$CONFIG_FILE"
if [ -n "${SYNOPKG_PKGUSER:-}" ] && [ -n "${SYNOPKG_PKGGROUP:-}" ]; then
  chown -R "$SYNOPKG_PKGUSER:$SYNOPKG_PKGGROUP" "$PKG_HOME" || true
fi

echo "[openclaw] starting service"
for attempt in {1..3}; do
  if "$PKG_DEST/bin/openclawctl" start; then
    echo "[openclaw] service started (attempt $attempt)"
    break
  else
    echo "[openclaw] start failed (attempt $attempt); retrying in 5s..." >&3
    sleep 5
  fi
done
if ! "$PKG_DEST/bin/openclawctl" status; then
  echo "[openclaw] ERROR: service failed to start; check $VERBOSE_LOG" >&3
  exit 1  # Fail install if service doesn't start
fi

echo "[openclaw] postinst done"
echo "[openclaw] Installation complete." >&3
exit 0
