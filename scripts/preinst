#!/bin/sh
set -eu
LOGFILE="${SYNOPKG_TEMP_LOGFILE:-/tmp/openclaw-preinst.log}"
exec >>"$LOGFILE" 2>&1

echo "[openclaw] preinst: starting" 
date

echo "[openclaw] PATH=$PATH"

if ! command -v node >/dev/null 2>&1; then
  echo "[openclaw] ERROR: Node.js is required (node not found)"
  exit 1
fi
if ! node --version 2>&1 | grep -Eq '^v(20|2[0-9]+|3[0-9]+)'; then
  echo "[openclaw] ERROR: Node.js 20+ required (found $(node --version))"
  exit 1
fi
if ! command -v npm >/dev/null 2>&1; then
  echo "[openclaw] ERROR: npm is required (npm not found)"
  exit 1
fi
if ! command -v curl >/dev/null 2>&1; then
  echo "[openclaw] ERROR: curl is required (curl not found)"
  exit 1
fi
if ! command -v tar >/dev/null 2>&1; then
  echo "[openclaw] ERROR: tar is required (tar not found)"
  exit 1
fi

echo "[openclaw] preinst: ok" 
exit 0
