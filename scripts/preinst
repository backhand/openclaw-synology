#!/bin/sh
set -eu
LOGFILE="${SYNOPKG_TEMP_LOGFILE:-/tmp/openclaw-preinst.log}"
# Keep UI output minimal; details go here
exec >>"$LOGFILE" 2>&1

if ! command -v node >/dev/null 2>&1; then
  echo "OpenClaw requires Node.js v22+. Install Synology 'Node.js v22' package first." > "$SYNOPKG_TEMP_LOGFILE"
  exit 1
fi
# Require Node >= 22
if ! node -e 'process.exit((+process.versions.node.split(".")[0] >= 22)?0:1)'; then
  echo "OpenClaw requires Node.js v22+. Current: $(node --version). Install Synology 'Node.js v22' package." > "$SYNOPKG_TEMP_LOGFILE"
  exit 1
fi

if ! command -v npm >/dev/null 2>&1; then
  echo "npm not found (install Node.js v22 package)" > "$SYNOPKG_TEMP_LOGFILE"
  exit 1
fi
if ! command -v curl >/dev/null 2>&1; then
  echo "curl not found" > "$SYNOPKG_TEMP_LOGFILE"
  exit 1
fi
if ! command -v tar >/dev/null 2>&1; then
  echo "tar not found" > "$SYNOPKG_TEMP_LOGFILE"
  exit 1
fi

# Minimal success confirmation
echo "OpenClaw pre-checks OK." > "$SYNOPKG_TEMP_LOGFILE"
exit 0
